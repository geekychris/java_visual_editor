<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            prefWidth="520" prefHeight="308" fx:controller="com.example.ContactFormController">
    <children>
        <Label text="Active:" layoutX="24" layoutY="28"/>
        <CheckBox fx:id="activeCheckBox" layoutX="180" layoutY="24" prefWidth="280" text=""/>
        <Label text="Age:" layoutX="24" layoutY="60"/>
        <Spinner fx:id="ageSpinner" layoutX="180" layoutY="56" prefWidth="280"/>
        <Label text="Birthday:" layoutX="24" layoutY="92"/>
        <DatePicker fx:id="birthdayDatePicker" layoutX="180" layoutY="88" prefWidth="280"
                    onMouseClicked="#birthdayDatePickerMouseClicked"/>
        <Label text="Class:" layoutX="24" layoutY="124"/>
        <TextField fx:id="classTextField" layoutX="180" layoutY="120" prefWidth="280"/>
        <Label text="Email:" layoutX="24" layoutY="156"/>
        <TextField fx:id="emailTextField" layoutX="180" layoutY="152" prefWidth="280"/>
        <Label text="Name:" layoutX="24" layoutY="188"/>
        <TextField fx:id="nameTextField" layoutX="180" layoutY="184" prefWidth="280"/>
        <Label text="Notes:" layoutX="24" layoutY="220"/>
        <TextField fx:id="notesTextField" layoutX="180" layoutY="216" prefWidth="280"/>
        <Button fx:id="saveBtn" text="Save" layoutX="360" layoutY="264" prefWidth="100" defaultButton="true"/>
    </children>
</AnchorPane>
