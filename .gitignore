# --- Gradle / build outputs -------------------------------------------------
.gradle/
build/
**/build/
**/.gradle/
!gradle-wrapper.properties

# --- Kotlin -----------------------------------------------------------------
.kotlin/
**/.kotlin/

# --- IntelliJ ---------------------------------------------------------------
