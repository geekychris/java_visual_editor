**/.idea/**
!**/.idea/runConfigurations/
!**/.idea/runConfigurations/**
*.iml

# Sandbox IDE state from runIde (logs, system, config — multi-GB possible)
.intellijPlatform/

# --- OS junk ----------------------------------------------------------------
.DS_Store
Thumbs.db

# --- Docs intermediates -----------------------------------------------------
docs/images/.tmp/

# --- Local secrets ----------------------------------------------------------
.env
.env.*
*.pem
*.key
secrets/
credentials.json
